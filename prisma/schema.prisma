generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─── Autenticación ────────────────────────────────────────────────────────────

enum Rol {
  ADMIN
  OPERADOR
}

model Usuario {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nombre    String
  rol       Rol      @default(OPERADOR)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  acciones         RegistroAccion[]
  cambiosDePrecios HistorialPrecioInsumo[]

  @@index([email])
}

// ─── Auditoría ────────────────────────────────────────────────────────────────

enum TipoAccion {
  CREAR
  EDITAR
  ELIMINAR
}

enum EntidadAccion {
  Insumo
  Formula
}

model RegistroAccion {
  id        String        @id @default(uuid())
  usuarioId String
  usuario   Usuario       @relation(fields: [usuarioId], references: [id])
  accion    TipoAccion
  entidad   EntidadAccion
  entidadId String?
  detalle   Json?
  createdAt DateTime      @default(now())

  @@index([usuarioId])
  @@index([createdAt])
}

// ─── Historial de precios ─────────────────────────────────────────────────────

model HistorialPrecioInsumo {
  id            String   @id @default(uuid())
  insumoId      String
  insumo        Insumo   @relation(fields: [insumoId], references: [id], onDelete: Cascade)
  precioAntes   Decimal  @db.Decimal(10, 2)
  precioDespues Decimal  @db.Decimal(10, 2)
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])
  createdAt     DateTime @default(now())

  @@index([insumoId])
  @@index([createdAt])
}

// ─── Insumos ──────────────────────────────────────────────────────────────────

model Insumo {
  id             String   @id @default(uuid())
  name           String   @unique
  suplier        String
  price          Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  codigoBejerman String?  @db.VarChar(20)

  usadoEn           FormulaDetalle[]
  historialPrecios  HistorialPrecioInsumo[]
  historialFormulas HistorialPrecioFormula[]

  @@index([codigoBejerman])
}

// ─── Fórmulas ─────────────────────────────────────────────────────────────────

model Formula {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(32)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items            FormulaDetalle[]
  comoIngrediente  FormulaDetalle[]         @relation("SubFormula")
  historialPrecios HistorialPrecioFormula[]
  codigoBejerman   String?                  @db.VarChar(20)

  @@index([codigoBejerman])
}

model FormulaDetalle {
  id       String  @id @default(uuid())
  cantidad Decimal @db.Decimal(10, 4)

  formulaId String
  formula   Formula @relation(fields: [formulaId], references: [id], onDelete: Cascade)

  insumoId String?
  insumo   Insumo? @relation(fields: [insumoId], references: [id])

  subFormulaId String?
  subFormula   Formula? @relation("SubFormula", fields: [subFormulaId], references: [id])

  @@index([formulaId])
  @@index([insumoId])
  @@index([subFormulaId])
}

model HistorialPrecioFormula {
  id        String   @id @default(uuid())
  formulaId String
  formula   Formula  @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  precio    Decimal  @db.Decimal(10, 2)
  // El insumo que disparó el cambio
  insumoId  String?
  insumo    Insumo?  @relation(fields: [insumoId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([formulaId])
  @@index([createdAt])
}

// ─── Bejerman: Artículos ──────────────────────────────────────────────────────

model BejArticulo {
  codigo        String   @id // art_CodGen
  descripcion   String   @db.VarChar(50)
  clasificacion String?  @db.VarChar(1) // A/B/C
  esProducido   Boolean  @default(false) // art_CircProd
  esVendido     Boolean  @default(false) // art_CircVta
  esComprado    Boolean  @default(false) // art_CircCpra
  updatedAt     DateTime

  ventasDetalle  BejVentaDet[]
  comprasDetalle BejCompraDet[]
  listaPrecios   BejListaPrecio[]
  npDetalle      BejNPDet[]

  @@map("bej_articulos")
}

// ─── Bejerman: Ventas ─────────────────────────────────────────────────────────

model BejVentaCab {
  id           Int      @id // cve_ID
  fecha        DateTime
  codCliente   String   @db.VarChar(6)
  razonSocial  String   @db.VarChar(40)
  importeTotal Decimal  @db.Decimal(15, 2)
  anulado      Boolean  @default(false)

  detalle BejVentaDet[]

  @@index([fecha])
  @@index([codCliente])
  @@map("bej_ventas_cab")
}

model BejVentaDet {
  id          Int         @id @default(autoincrement())
  ventaId     Int
  venta       BejVentaCab @relation(fields: [ventaId], references: [id])
  artCodigo   String      @db.VarChar(20)
  articulo    BejArticulo @relation(fields: [artCodigo], references: [codigo])
  descripcion String      @db.VarChar(50)
  cantidad    Decimal     @db.Decimal(15, 4)
  neto        Decimal     @db.Decimal(15, 2)
  precioCosto Decimal     @db.Decimal(15, 2)
  fecha       DateTime

  @@index([artCodigo])
  @@index([ventaId])
  @@index([fecha])
  @@map("bej_ventas_det")
}

// ─── Bejerman: Notas de Pedido ────────────────────────────────────────────────

model BejNPCab {
  id          Int      @id // scv_ID
  fecha       DateTime
  codCliente  String   @db.VarChar(6)
  razonSocial String   @db.VarChar(40)

  detalle BejNPDet[]

  @@index([fecha])
  @@index([codCliente])
  @@map("bej_np_cab")
}

model BejNPDet {
  id           Int         @id @default(autoincrement())
  npId         Int
  np           BejNPCab    @relation(fields: [npId], references: [id])
  artCodigo    String      @db.VarChar(20)
  articulo     BejArticulo @relation(fields: [artCodigo], references: [codigo])
  descripcion  String      @db.VarChar(50)
  cantidad     Decimal     @db.Decimal(15, 4)
  importeTotal Decimal     @db.Decimal(15, 2)
  precioUn     Decimal     @db.Decimal(15, 2)
  fecha        DateTime

  @@index([artCodigo])
  @@index([npId])
  @@index([fecha])
  @@map("bej_np_det")
}

// ─── Bejerman: Compras ────────────────────────────────────────────────────────

model BejCompraCab {
  id           Int      @id
  fecha        DateTime
  codProveedor String   @db.VarChar(6)
  razonSocial  String   @db.VarChar(40)
  importeTotal Decimal  @db.Decimal(15, 2)
  anulado      Boolean  @default(false)

  detalle BejCompraDet[]

  @@index([fecha])
  @@map("bej_compras_cab")
}

model BejCompraDet {
  id         Int          @id @default(autoincrement())
  compraId   Int
  compra     BejCompraCab @relation(fields: [compraId], references: [id])
  artCodigo  String       @db.VarChar(20)
  articulo   BejArticulo  @relation(fields: [artCodigo], references: [codigo])
  cantidad   Decimal      @db.Decimal(15, 4)
  neto       Decimal      @db.Decimal(15, 2)
  precioUnit Decimal      @db.Decimal(15, 2)
  fecha      DateTime

  @@index([artCodigo])
  @@index([fecha])
  @@map("bej_compras_det")
}

// ─── Bejerman: Lista de Precios ───────────────────────────────────────────────

model BejListaPrecio {
  id        Int         @id @default(autoincrement())
  listaCod  String      @db.VarChar(3)
  artCodigo String      @db.VarChar(20)
  articulo  BejArticulo @relation(fields: [artCodigo], references: [codigo])
  precio    Decimal     @db.Decimal(15, 2)
  fechaMod  DateTime

  @@unique([listaCod, artCodigo])
  @@index([artCodigo])
  @@map("bej_lista_precios")
}

// ─── Bejerman: Producción ─────────────────────────────────────────────────────

model BejProdFormula {
  formula    String    @id @db.VarChar(32)
  batch      Decimal   @db.Decimal(15, 4)
  costoTotal Decimal   @db.Decimal(15, 2)
  costoComp  Decimal   @db.Decimal(15, 2)
  costoRrhh  Decimal   @db.Decimal(15, 2)
  costoMaq   Decimal   @db.Decimal(15, 2)
  costoInd   Decimal   @db.Decimal(15, 2)
  fechaCosto DateTime?
  vigente    Boolean   @default(true)

  componentes BejProdFormulaComp[]
  producidos  BejProdFormulaProducido[]

  @@map("bej_prod_formulas")
}

model BejProdFormulaComp {
  id          Int            @id @default(autoincrement())
  formula     String         @db.VarChar(32)
  prodFormula BejProdFormula @relation(fields: [formula], references: [formula])
  componente  String         @db.VarChar(41)
  cantidad    Decimal        @db.Decimal(15, 4)

  @@index([formula])
  @@map("bej_prod_formula_comp")
}

model BejProdFormulaProducido {
  id          Int            @id @default(autoincrement())
  formula     String         @db.VarChar(32)
  prodFormula BejProdFormula @relation(fields: [formula], references: [formula])
  artCodigo   String         @db.VarChar(20)
  cantidad    Decimal        @db.Decimal(15, 4)

  @@index([formula])
  @@index([artCodigo])
  @@map("bej_prod_formula_producidos")
}

// ─── Metadata del ETL ─────────────────────────────────────────────────────────

model BejEtlLog {
  id        Int      @id @default(autoincrement())
  tabla     String   @db.VarChar(50)
  registros Int
  durMs     Int
  estado    String   @db.VarChar(10) // "ok" | "error"
  error     String?  @db.Text
  createdAt DateTime @default(now())

  @@map("bej_etl_log")
}

model BejArticuloMapeo {
  id         Int     @id @default(autoincrement())
  codigoLili String  @db.VarChar(20)
  codigoCane String  @db.VarChar(20)
  verificado Boolean @default(false) // true = revisado manualmente

  @@unique([codigoLili])
  @@index([codigoCane])
  @@map("bej_articulo_mapeo")
}

// ─── LILI: Artículos ──────────────────────────────────────────────────────────

model LiliArticulo {
  codigo        String   @id
  descripcion   String   @db.VarChar(50)
  clasificacion String?  @db.VarChar(1)
  esProducido   Boolean  @default(false)
  esVendido     Boolean  @default(false)
  esComprado    Boolean  @default(false)
  updatedAt     DateTime

  ventasDetalle LiliVentaDet[]
  listaPrecios  LiliListaPrecio[]

  @@map("lili_articulos")
}

// ─── LILI: Ventas ─────────────────────────────────────────────────────────────

model LiliVentaCab {
  id           Int      @id
  fecha        DateTime
  codCliente   String   @db.VarChar(6)
  razonSocial  String   @db.VarChar(40)
  importeTotal Decimal  @db.Decimal(15, 2)
  tipoComp     String   @db.VarChar(5)

  detalle LiliVentaDet[]

  @@index([fecha])
  @@index([codCliente])
  @@map("lili_ventas_cab")
}

model LiliVentaDet {
  id          Int          @id @default(autoincrement())
  ventaId     Int
  venta       LiliVentaCab @relation(fields: [ventaId], references: [id])
  artCodigo   String       @db.VarChar(20)
  articulo    LiliArticulo @relation(fields: [artCodigo], references: [codigo])
  descripcion String       @db.VarChar(50)
  cantidad    Decimal      @db.Decimal(15, 4)
  neto        Decimal      @db.Decimal(15, 2)
  fecha       DateTime

  @@index([artCodigo])
  @@index([ventaId])
  @@index([fecha])
  @@map("lili_ventas_det")
}

// ─── LILI: Lista de Precios ───────────────────────────────────────────────────

model LiliListaPrecio {
  id        Int          @id @default(autoincrement())
  listaCod  String       @db.VarChar(3)
  artCodigo String       @db.VarChar(20)
  articulo  LiliArticulo @relation(fields: [artCodigo], references: [codigo])
  precio    Decimal      @db.Decimal(15, 2)
  fechaMod  DateTime

  @@unique([listaCod, artCodigo])
  @@index([artCodigo])
  @@map("lili_lista_precios")
}
