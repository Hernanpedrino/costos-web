generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}
model Insumo {
  id        String   @id @default(uuid()) // Genera automáticamente un string UUID
  name      String   @unique
  suplier   String
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usadoEn   FormulaDetalle[]
}

model Formula {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(32)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     FormulaDetalle[]

  // Relación: Cuando esta fórmula se usa como ingrediente
  comoIngrediente FormulaDetalle[] @relation("SubFormula")
}

model FormulaDetalle {
  id        String   @id @default(uuid())
  cantidad  String 

  // Relación con la fórmula "padre"
  formulaId String
  formula   Formula @relation(fields: [formulaId], references: [id], onDelete: Cascade)

  // El ingrediente puede ser un Insumo (UUID)
  insumoId  String?
  insumo    Insumo? @relation(fields: [insumoId], references: [id])

  // O el ingrediente puede ser otra Fórmula (UUID)
  subFormulaId String?
  subFormula   Formula? @relation("SubFormula", fields: [subFormulaId], references: [id])

  @@index([formulaId])
  @@index([insumoId])
  @@index([subFormulaId])
}
