generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─── Autenticación ────────────────────────────────────────────────────────────

enum Rol {
  ADMIN
  OPERADOR
}

model Usuario {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nombre    String
  rol       Rol      @default(OPERADOR)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  acciones         RegistroAccion[]
  cambiosDePrecios HistorialPrecioInsumo[]

  @@index([email])
}

// ─── Auditoría ────────────────────────────────────────────────────────────────

enum TipoAccion {
  CREAR
  EDITAR
  ELIMINAR
}

enum EntidadAccion {
  Insumo
  Formula
}

model RegistroAccion {
  id        String        @id @default(uuid())
  usuarioId String
  usuario   Usuario       @relation(fields: [usuarioId], references: [id])
  accion    TipoAccion
  entidad   EntidadAccion
  entidadId String?
  detalle   Json?
  createdAt DateTime      @default(now())

  @@index([usuarioId])
  @@index([createdAt])
}

// ─── Historial de precios ─────────────────────────────────────────────────────

model HistorialPrecioInsumo {
  id            String   @id @default(uuid())
  insumoId      String
  insumo        Insumo   @relation(fields: [insumoId], references: [id], onDelete: Cascade)
  precioAntes   Decimal  @db.Decimal(10, 2)
  precioDespues Decimal  @db.Decimal(10, 2)
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])
  createdAt     DateTime @default(now())

  @@index([insumoId])
  @@index([createdAt])
}

// ─── Insumos ──────────────────────────────────────────────────────────────────

model Insumo {
  id        String   @id @default(uuid())
  name      String   @unique
  suplier   String
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usadoEn          FormulaDetalle[]
  historialPrecios HistorialPrecioInsumo[]
}

// ─── Fórmulas ─────────────────────────────────────────────────────────────────

model Formula {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(32)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items           FormulaDetalle[]
  comoIngrediente FormulaDetalle[] @relation("SubFormula")
}

model FormulaDetalle {
  id       String  @id @default(uuid())
  cantidad Decimal @db.Decimal(10, 4)

  formulaId    String
  formula      Formula  @relation(fields: [formulaId], references: [id], onDelete: Cascade)

  insumoId     String?
  insumo       Insumo?  @relation(fields: [insumoId], references: [id])

  subFormulaId String?
  subFormula   Formula? @relation("SubFormula", fields: [subFormulaId], references: [id])

  @@index([formulaId])
  @@index([insumoId])
  @@index([subFormulaId])
}
