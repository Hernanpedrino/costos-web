generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "mysql"
}

model inputs {
  id        String   @id @default(uuid())
  name      String
  suplier   String
  price     String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}
